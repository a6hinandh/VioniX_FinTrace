# FinTrace AI — Environment Configuration
# Copy this file to .env and adjust values as needed.

# API base URL for backend services (uses mock data when empty)
VITE_API_BASE_URL=

# Enable real-time transaction feed simulation (true/false)
VITE_FEATURE_REALTIME=true

# Enable analytics event tracking (true/false)
VITE_ENABLE_ANALYTICS=false

# Application environment label displayed in header
VITE_APP_ENV=Mock Feed
